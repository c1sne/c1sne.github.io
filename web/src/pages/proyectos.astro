---
import Layout from '../layouts/Layout.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');

const visibleProjects = allProjects
  .filter(p => !p.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);

const featuredProjects = visibleProjects.filter(p => p.data.featured);
const otherProjects = visibleProjects.filter(p => !p.data.featured);
---

<Layout
  title="Proyectos"
  description="Proyectos seleccionados de Andrés Cisneros. Instalación sonora, software creativo, instalación interactiva, investigación escénica."
>
  <div class="page-projects">
    <div class="container">

      <header class="page-header">
        <div class="header-label">
          <span class="label-line"></span>
          <span>Trabajo</span>
        </div>
        <h1 class="page-title">Proyectos</h1>
        <p class="page-desc">
          Selección de proyectos de instalación, investigación, software y escena.
          <!-- TODO: ajustar descripción con texto propio -->
        </p>
      </header>

      {featuredProjects.length > 0 && (
        <section aria-labelledby="featured-h2" class="projects-section">
          <h2 id="featured-h2" class="projects-section-label">Destacados</h2>
          <ProjectGrid projects={featuredProjects} />
        </section>
      )}

      {otherProjects.length > 0 && (
        <section aria-labelledby="other-h2" class="projects-section">
          {featuredProjects.length > 0 && (
            <h2 id="other-h2" class="projects-section-label">Otros proyectos</h2>
          )}
          <ProjectGrid projects={otherProjects} />
        </section>
      )}

      {visibleProjects.length === 0 && (
        <div class="empty-state">
          <p class="todo">[TODO: agregar proyectos en src/content/projects/]</p>
        </div>
      )}

    </div>
  </div>
</Layout>

<style>
  .page-projects {
    padding-block: var(--space-2xl);
  }

  .page-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border);
  }

  .header-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--copper);
    margin-bottom: var(--space-md);
  }

  .label-line {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--copper);
    flex-shrink: 0;
  }

  .page-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 300;
    color: var(--white);
    margin-bottom: var(--space-md);
  }

  .page-desc {
    font-size: 1rem;
    color: var(--text-muted);
    line-height: 1.7;
    max-width: 560px;
  }

  .projects-section {
    margin-bottom: var(--space-2xl);
  }

  .projects-section-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-weight: 400;
    margin-bottom: var(--space-lg);
  }

  .empty-state {
    padding: var(--space-2xl);
    text-align: center;
    border: 1px dashed var(--border);
  }
</style>
