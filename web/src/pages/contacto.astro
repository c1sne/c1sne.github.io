---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contacto"
  description="Contacto con Andrés Cisneros, artista audiovisual de Lima, Perú. Residencias, festivales, colaboraciones y proyectos."
>
  <div class="page-contacto">
    <div class="container">

      <header class="page-header">
        <div class="header-label">
          <span class="label-line"></span>
          <span>Escribir</span>
        </div>
        <h1 class="page-title">Contacto</h1>
      </header>

      <div class="contact-layout">

        <!-- Columna principal -->
        <div class="contact-main">
          <p class="contact-intro">
            Disponible para residencias, festivales, convocatorias, colaboraciones artísticas y proyectos técnicos.
            <!-- TODO: ajustar con tu disponibilidad actual -->
          </p>

          <div class="contact-primary">
            <span class="contact-label">Email principal</span>
            <a href="mailto:a.cisneros@pucp.edu.pe" class="contact-email">
              a.cisneros@pucp.edu.pe
            </a>
          </div>

          <div class="contact-divider"></div>

          <div class="contact-contexts">
            <h2 class="contexts-title">Contextos de contacto</h2>
            <div class="contexts-grid">
              <div class="context-item">
                <h3 class="context-name">Residencias y convocatorias</h3>
                <p class="context-desc">Para postulaciones a residencias artísticas, festivales y programas de investigación. Puedo enviar dossier, statement, ficha técnica y referencias.</p>
              </div>
              <div class="context-item">
                <h3 class="context-name">Colaboraciones artísticas</h3>
                <p class="context-desc">Para proyectos de colaboración con artistas, compañías escénicas o colectivos. Trabajo en diseño audiovisual, técnica escénica e instalación.</p>
              </div>
              <div class="context-item">
                <h3 class="context-name">Proyectos técnicos</h3>
                <p class="context-desc">Para proyectos que requieran diseño electrónico, software creativo, sistemas de show-control o integración técnica especializada.</p>
              </div>
              <div class="context-item">
                <h3 class="context-name">Prensa y difusión</h3>
                <p class="context-desc">Para solicitudes de prensa, documentación, imágenes o información sobre proyectos específicos.</p>
              </div>
            </div>
          </div>
        </div>

        <!-- Columna lateral -->
        <aside class="contact-sidebar">

          <div class="sidebar-block">
            <h2 class="sidebar-title">Presencia en línea</h2>

            <!-- TODO: agregar links reales cuando estén disponibles -->
            <div class="external-links">
              <div class="ext-link-item">
                <span class="ext-label">Vimeo</span>
                <span class="todo">[TODO: agregar URL]</span>
              </div>
              <div class="ext-link-item">
                <span class="ext-label">Instagram</span>
                <span class="todo">[TODO: agregar URL si aplica]</span>
              </div>
              <div class="ext-link-item">
                <span class="ext-label">GitHub</span>
                <span class="todo">[TODO: agregar URL]</span>
              </div>
              <div class="ext-link-item">
                <span class="ext-label">Bandcamp / SoundCloud</span>
                <span class="todo">[TODO: si aplica]</span>
              </div>
            </div>
          </div>

          <div class="sidebar-block">
            <h2 class="sidebar-title">Ubicación</h2>
            <p class="sidebar-text">Lima, Perú</p>
            <p class="sidebar-note">Disponible para proyectos y residencias internacionales.</p>
          </div>

          <div class="sidebar-block">
            <h2 class="sidebar-title">CV</h2>
            <a href="/cv" class="sidebar-link">Ver CV en línea →</a>
            <!-- TODO: cuando tengas PDF:
            <a href="/cv/cv-andres-cisneros.pdf" download class="sidebar-link">Descargar PDF →</a>
            -->
          </div>

        </aside>
      </div>
    </div>
  </div>
</Layout>

<style>
  .page-contacto {
    padding-block: var(--space-2xl);
  }

  .page-header {
    margin-bottom: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--border);
  }

  .header-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--copper);
    margin-bottom: var(--space-md);
  }

  .label-line {
    display: block;
    width: 24px;
    height: 1px;
    background: var(--copper);
    flex-shrink: 0;
  }

  .page-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 300;
    color: var(--white);
  }

  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: var(--space-2xl);
    align-items: start;
  }

  .contact-intro {
    font-size: 1.1rem;
    color: var(--text-muted);
    line-height: 1.75;
    margin-bottom: var(--space-xl);
    max-width: 560px;
  }

  .contact-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    margin-bottom: 0.4rem;
  }

  .contact-email {
    display: inline-block;
    font-size: clamp(1.2rem, 3vw, 1.75rem);
    color: var(--copper-light);
    text-decoration: none;
    font-family: var(--font-display);
    font-weight: 300;
    letter-spacing: -0.01em;
    transition: color 0.2s;
    line-height: 1.2;
  }

  .contact-email:hover {
    color: var(--white);
  }

  .contact-divider {
    height: 1px;
    background: var(--border);
    margin-block: var(--space-xl);
  }

  .contexts-title {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--copper);
    font-weight: 400;
    margin-bottom: var(--space-lg);
  }

  .contexts-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
  }

  .context-item {
    background: var(--bg-2);
    padding: var(--space-lg);
  }

  .context-name {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .context-desc {
    font-size: 0.82rem;
    color: var(--text-muted);
    line-height: 1.65;
  }

  /* Sidebar */
  .contact-sidebar {
    position: sticky;
    top: calc(var(--nav-h) + var(--space-lg));
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
  }

  .sidebar-block {
    border-top: 1px solid var(--border);
    padding-top: var(--space-md);
  }

  .sidebar-title {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-dim);
    font-weight: 400;
    margin-bottom: 0.75rem;
  }

  .external-links {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .ext-link-item {
    display: grid;
    grid-template-columns: 80px 1fr;
    gap: 0.5rem;
    align-items: baseline;
  }

  .ext-label {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
  }

  .ext-link-item a {
    font-size: 0.8rem;
    color: var(--copper-light);
    text-decoration: none;
    transition: color 0.2s;
  }

  .ext-link-item a:hover { color: var(--white); }

  .sidebar-text {
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 0.25rem;
  }

  .sidebar-note {
    font-size: 0.75rem;
    color: var(--text-dim);
  }

  .sidebar-link {
    font-size: 0.82rem;
    color: var(--copper-light);
    text-decoration: none;
    display: block;
    margin-bottom: 0.35rem;
    transition: color 0.2s;
  }

  .sidebar-link:hover { color: var(--white); }

  @media (max-width: 900px) {
    .contact-layout {
      grid-template-columns: 1fr;
    }
    .contact-sidebar {
      position: static;
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: var(--space-lg);
    }
    .contexts-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 640px) {
    .contact-sidebar { grid-template-columns: 1fr; }
  }
</style>
