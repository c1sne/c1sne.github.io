---
import Layout from '../layouts/Layout.astro';
import ProjectGrid from '../components/ProjectGrid.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured && !p.data.hidden)
  .sort((a, b) => a.data.order - b.data.order)
  .slice(0, 3);
---

<Layout
  title="Andrés Cisneros"
  description="Andrés Cisneros — Artista audiovisual de Lima, Perú. Nuevos medios, escena expandida, sonido, luz, electrónica, sensores y territorio."
>
  <!-- Hero -->
  <section class="hero" aria-labelledby="hero-heading">
    <div class="container">
      <div class="hero-inner">
        <div class="hero-label">
          <span class="label-line"></span>
          <span class="label-text">Artista audiovisual · Lima, Perú</span>
        </div>

        <h1 id="hero-heading" class="hero-title">
          <!-- TODO: revisar y ajustar este statement con tu voz propia -->
          Trabajo en el cruce entre<br />
          <em class="accent-word">escucha, máquinas</em><br />
          y <em class="accent-word">territorio</em>.
        </h1>

        <p class="hero-statement">
          <!-- TODO: reemplazar con statement definitivo -->
          Mi práctica cruza el audiovisual experimental, la escena expandida, el sonido, la luz, la electrónica, los sensores y los sistemas técnicos. Trabajo con nuevos medios como campo de investigación: herramientas, protocolos, circuitos y código como formas de pensamiento y presencia.
        </p>

        <div class="hero-tags">
          <span>nuevos medios</span>
          <span>escena expandida</span>
          <span>sonido</span>
          <span>electrónica</span>
          <span>sensores</span>
          <span>territorio</span>
          <span>instalación</span>
          <span>software creativo</span>
        </div>

        <div class="hero-actions">
          <a href="/proyectos" class="btn btn-primary">Ver proyectos</a>
          <a href="/investigacion" class="btn btn-secondary">Líneas de investigación</a>
        </div>
      </div>
    </div>

    <!-- Decoración de fondo -->
    <div class="hero-bg" aria-hidden="true">
      <div class="bg-line bg-line--v1"></div>
      <div class="bg-line bg-line--v2"></div>
      <div class="bg-line bg-line--h"></div>
    </div>
  </section>

  <!-- Proyectos destacados -->
  {featuredProjects.length > 0 && (
    <section class="section-featured" aria-labelledby="featured-heading">
      <div class="container">
        <div class="section-header">
          <div class="section-label-group">
            <span class="section-label">Proyectos seleccionados</span>
            <h2 id="featured-heading" class="section-title">Trabajo reciente</h2>
          </div>
          <a href="/proyectos" class="see-all">Ver todos →</a>
        </div>

        <ProjectGrid projects={featuredProjects} />
      </div>
    </section>
  )}

  <!-- Statement / práctica -->
  <section class="section-practice">
    <div class="container">
      <div class="practice-inner">
        <div class="practice-left">
          <span class="section-label">Práctica</span>
          <h2 class="practice-title">
            Sistemas técnicos<br />como pensamiento
          </h2>
        </div>
        <div class="practice-right">
          <!-- TODO: reemplazar con texto definitivo sobre tu práctica -->
          <p>Estudio Comunicación Audiovisual en la PUCP y desarrollo una práctica que no separa el arte de la técnica. Los circuitos, el código, los sensores y los protocolos son materiales de trabajo y de pensamiento.</p>
          <p>Me interesa la escena como campo expandido: sistemas de luz, sonido y video que operan como agentes, no como soporte. Me interesa el territorio como inscripción de tiempo y memoria. Me interesa la máquina que escucha.</p>
          <a href="/bio" class="text-link">Leer bio completa →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Áreas de trabajo rápidas -->
  <section class="section-areas">
    <div class="container">
      <span class="section-label">Áreas</span>
      <div class="areas-grid">
        {[
          { n: '01', title: 'Instalación interactiva', desc: 'Sistemas que responden a presencia, movimiento, sonido y luz ambiental.' },
          { n: '02', title: 'Escena expandida', desc: 'Dramaturgia técnica, sistemas autónomos, presencia maquínica en espacio escénico.' },
          { n: '03', title: 'Electrónica y sensores', desc: 'Circuitos construidos a medida. ESP32, sensores ambientales, actuadores físicos.' },
          { n: '04', title: 'Software creativo', desc: 'Herramientas propias para escena, show-control, automatización y síntesis audiovisual.' },
        ].map(area => (
          <div class="area-item">
            <span class="area-n">{area.n}</span>
            <h3 class="area-title">{area.title}</h3>
            <p class="area-desc">{area.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA contacto -->
  <section class="section-cta">
    <div class="container">
      <div class="cta-inner">
        <div>
          <h2 class="cta-title">Residencias · Festivales · Colaboraciones</h2>
          <p class="cta-sub">Disponible para proyectos, residencias y convocatorias internacionales.</p>
        </div>
        <a href="/contacto" class="btn btn-primary">Contacto</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ── Hero ───────────────────────────────────────────────────────── */
  .hero {
    position: relative;
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding-block: var(--space-2xl) var(--space-xl);
    overflow: hidden;
  }

  .hero .container { position: relative; z-index: 1; }

  .hero-inner {
    max-width: 760px;
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .hero-label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .label-line {
    display: block;
    width: 32px;
    height: 1px;
    background: var(--copper);
    flex-shrink: 0;
  }

  .label-text {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--copper);
  }

  .hero-title {
    font-size: clamp(2.5rem, 7vw, 5rem);
    font-weight: 300;
    line-height: 1.05;
    color: var(--white);
    letter-spacing: -0.02em;
  }

  .accent-word {
    font-style: normal;
    color: var(--copper-light);
  }

  .hero-statement {
    font-size: 1.05rem;
    color: var(--text-muted);
    line-height: 1.75;
    max-width: 600px;
  }

  .hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .hero-tags span {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-dim);
    border: 1px solid var(--border);
    padding: 0.25em 0.65em;
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .btn {
    font-family: var(--font-sans);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    padding: 0.7em 1.6em;
    text-decoration: none;
    transition: all 0.2s ease;
    display: inline-block;
  }

  .btn-primary {
    background: var(--copper);
    color: var(--bg);
    border: 1px solid var(--copper);
  }

  .btn-primary:hover {
    background: var(--copper-light);
    border-color: var(--copper-light);
    color: var(--bg);
  }

  .btn-secondary {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }

  .btn-secondary:hover {
    border-color: var(--copper-dim);
    color: var(--white);
  }

  /* BG decorativo */
  .hero-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .bg-line {
    position: absolute;
    background: rgba(184, 115, 51, 0.06);
  }

  .bg-line--v1 { width: 1px; top: 0; bottom: 0; left: 55%; }
  .bg-line--v2 { width: 1px; top: 0; bottom: 0; left: 75%; }
  .bg-line--h { height: 1px; left: 0; right: 0; top: 60%; }

  /* ── Secciones ──────────────────────────────────────────────────── */
  .section-featured,
  .section-practice,
  .section-areas,
  .section-cta {
    padding-block: var(--space-2xl);
  }

  .section-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: var(--space-xl);
    gap: var(--space-md);
  }

  .section-label {
    display: block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--copper);
    margin-bottom: 0.5rem;
  }

  .section-title {
    color: var(--white);
    margin: 0;
  }

  .see-all {
    font-size: 0.8rem;
    color: var(--copper-light);
    text-decoration: none;
    letter-spacing: 0.04em;
    flex-shrink: 0;
    transition: color 0.2s;
  }

  .see-all:hover { color: var(--white); }

  /* Practice */
  .practice-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  .practice-title {
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 400;
    color: var(--white);
    margin-top: var(--space-sm);
  }

  .practice-right {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .practice-right p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.75;
  }

  .text-link {
    font-size: 0.82rem;
    color: var(--copper-light);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.2s;
    margin-top: 0.5rem;
    align-self: flex-start;
  }

  .text-link:hover { color: var(--white); }

  /* Areas */
  .areas-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1px;
    background: var(--border);
    border: 1px solid var(--border);
    margin-top: var(--space-lg);
  }

  .area-item {
    background: var(--bg-2);
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .area-n {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--copper-dim);
    letter-spacing: 0.08em;
  }

  .area-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--white);
  }

  .area-desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* CTA */
  .section-cta {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--bg-2);
    padding-block: var(--space-xl);
  }

  .cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-xl);
    flex-wrap: wrap;
  }

  .cta-title {
    font-size: clamp(1.3rem, 2.5vw, 1.8rem);
    color: var(--white);
    margin-bottom: 0.5rem;
  }

  .cta-sub {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .areas-grid { grid-template-columns: repeat(2, 1fr); }
    .practice-inner { grid-template-columns: 1fr; gap: var(--space-xl); }
  }

  @media (max-width: 640px) {
    .areas-grid { grid-template-columns: 1fr; }
    .hero { min-height: 80vh; }
  }
</style>
