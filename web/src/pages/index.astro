---
import Layout from '../layouts/Layout.astro';
import HydraSketch from '../components/HydraSketch.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter(p => p.data.featured && !p.data.hidden)
  .sort((a, b) => a.data.order - b.data.order);
---

<Layout
  title="Andrés Cisneros"
  description="Andrés Cisneros — Artista audiovisual de Lima, Perú. Nuevos medios, escena expandida, sonido, luz, electrónica, sensores y territorio."
>

  <!-- Canvas Hydra principal -->
  <section class="hydra-section" aria-label="Sketch visual">
    <div class="hydra-outer">
      <HydraSketch />

      <!-- Overlay mínimo -->
      <div class="hydra-overlay">
        <div class="overlay-name">
          <span class="name-main">Andrés Cisneros</span>
          <span class="name-sub">audiovisual · escena · sonido · Lima</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Proyectos: lista compacta -->
  <section class="projects-strip">
    <div class="container">
      <div class="strip-header">
        <span class="strip-label">Obra seleccionada</span>
        <a href="/proyectos" class="strip-all">Ver todo →</a>
      </div>
      <ul class="project-list">
        {featuredProjects.map((p) => (
          <li class="project-row">
            <a href={`/proyectos/${p.data.slug}`} class="project-row-link">
              <span class="row-year">{p.data.year}</span>
              <span class="row-title">{p.data.title}</span>
              <span class="row-cats">
                {p.data.categories.slice(0, 2).join(' · ')}
              </span>
              <span class="row-arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

</Layout>

<style>
  /* ── Canvas section ─────────────────────────────────────────── */
  :global(.site-header) {
    background: rgba(10, 10, 10, 0.36);
    border-bottom-color: transparent;
  }

  .hydra-section {
    width: 100%;
    margin-top: calc(var(--nav-h) * -1);
  }

  .hydra-outer {
    position: relative;
    width: 100%;
  }

  /* Overlay de texto sobre el canvas — pegado al borde derecho, vertical */
  .hydra-overlay {
    position: absolute;
    inset: 0;
    pointer-events: none;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    padding: clamp(0.75rem, 2vw, 1.5rem);
  }

  .overlay-name {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
    writing-mode: vertical-rl;
    text-orientation: mixed;
    transform: rotate(180deg);
  }

  .name-main {
    font-family: var(--font-display);
    font-size: clamp(0.75rem, 1.4vw, 1rem);
    font-weight: 400;
    color: rgba(240, 236, 228, 0.75);
    letter-spacing: 0.05em;
    line-height: 1;
  }

  .name-sub {
    font-family: var(--font-mono);
    font-size: clamp(0.5rem, 0.75vw, 0.62rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(184, 115, 51, 0.7);
  }

  /* ── Projects strip ─────────────────────────────────────────── */
  .projects-strip {
    padding-block: var(--space-xl) var(--space-2xl);
  }

  .strip-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-md);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--border);
  }

  .strip-label {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--copper);
  }

  .strip-all {
    font-size: 0.78rem;
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 0.04em;
    transition: color 0.2s;
  }

  .strip-all:hover { color: var(--white); }

  .project-list {
    list-style: none;
  }

  .project-row {
    border-bottom: 1px solid var(--border);
  }

  .project-row-link {
    display: grid;
    grid-template-columns: 48px 1fr auto 1.5rem;
    align-items: center;
    gap: var(--space-lg);
    padding-block: var(--space-md);
    text-decoration: none;
    transition: background 0.15s;
  }

  .project-row-link:hover {
    background: var(--bg-2);
  }

  .project-row-link:hover .row-arrow {
    color: var(--copper-light);
    transform: translateX(3px);
  }

  .row-year {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  .row-title {
    font-family: var(--font-display);
    font-size: clamp(1rem, 2vw, 1.3rem);
    font-weight: 400;
    color: var(--white);
    letter-spacing: -0.01em;
  }

  .row-cats {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-dim);
    text-align: right;
  }

  .row-arrow {
    font-size: 0.85rem;
    color: var(--text-dim);
    transition: color 0.2s, transform 0.2s;
    text-align: right;
  }

  @media (max-width: 640px) {
    .project-row-link {
      grid-template-columns: 36px 1fr 1rem;
    }
    .row-cats { display: none; }
  }
</style>
