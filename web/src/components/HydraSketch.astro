---
// Hydra synth live-coding visual — carga hydra-synth desde CDN.
// El sketch rescata el visual del antiguo c1sne.github.io.
---

<div class="hydra-wrap" aria-hidden="true">
  <canvas id="hydra-canvas"></canvas>
</div>

<script is:inline>
  (function () {
    var canvas = document.getElementById('hydra-canvas');
    if (!canvas) return;

    var hydra = null;
    var resizeFrame = null;

    function physicalDims() {
      var rect = canvas.getBoundingClientRect();
      var dpr = window.devicePixelRatio || 1;
      // Renderizar en resolución física real, sin tope artificial
      return {
        w: Math.max(1, Math.round(rect.width  * dpr)),
        h: Math.max(1, Math.round(rect.height * dpr)),
      };
    }

    function applySize() {
      var d = physicalDims();
      if (canvas.width === d.w && canvas.height === d.h) return;
      canvas.width  = d.w;
      canvas.height = d.h;
      if (hydra && typeof window.setResolution === 'function') {
        window.setResolution(d.w, d.h);
      }
    }

    function scheduleResize() {
      if (resizeFrame) cancelAnimationFrame(resizeFrame);
      resizeFrame = requestAnimationFrame(applySize);
    }

    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/hydra-synth@1.3.29/dist/hydra-synth.js';

    s.onload = function () {
      // Dimensionar el canvas ANTES de que Hydra cree el contexto WebGL
      applySize();

      hydra = new Hydra({
        canvas: canvas,
        detectAudio: false,
        enableStreamCapture: false,
        pb: false,
      });

      // Forzar la resolución correcta después de init
      var d = physicalDims();
      if (typeof window.setResolution === 'function') {
        window.setResolution(d.w, d.h);
      }

      // Mouse con inercia suave — influencia mínima sobre el sketch
      var mx = 0.5, my = 0.5, tx = 0.5, ty = 0.5;
      window.addEventListener('mousemove', function(e) {
        tx = e.clientX / window.innerWidth;
        ty = e.clientY / window.innerHeight;
      }, { passive: true });
      (function lerp() {
        mx += (tx - mx) * 0.03;
        my += (ty - my) * 0.03;
        requestAnimationFrame(lerp);
      })();

      // Sketch original tranquilo — mouse apenas mueve ±200 el voronoi
      shape(6)
        .modulate(voronoi(() => 2000 + (mx - 0.5) * 400))
        .pixelate(
          () => 120 + (my - 0.5) * 20,
          () => 68  + (my - 0.5) * 12
        )
        .layer(noise(3).luma(0.1).scale(4, 4))
        .blend(src(o0).luma(0.1).modulate(voronoi(0.1)))
        .colorama(0.06, 0, 0.1)
        .blend(o0)
        .blend(o0)
        .out(o0);
    };

    s.onerror = function () {};

    document.head.appendChild(s);

    if ('ResizeObserver' in window) {
      new ResizeObserver(scheduleResize).observe(canvas);
    } else {
      window.addEventListener('resize', scheduleResize, { passive: true });
    }
  })();
</script>

<style>
  .hydra-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    position: relative;
    background: #0a0a0a;
    overflow: hidden;
  }

  #hydra-canvas {
    display: block;
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
    /* Sin interpolación adicional — el canvas ya está en resolución física */
    image-rendering: auto;
    -webkit-font-smoothing: antialiased;
  }
</style>
