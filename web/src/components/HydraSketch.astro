---
// Hydra synth live-coding visual — carga hydra-synth desde CDN.
// El sketch rescata el visual del antiguo c1sne.github.io.
---

<div class="hydra-wrap" aria-hidden="true">
  <canvas id="hydra-canvas"></canvas>
</div>

<script is:inline>
  (function () {
    var canvas = document.getElementById('hydra-canvas');
    if (!canvas) return;

    var hydra = null;
    var resizeFrame = null;
    var maxDpr = 2;

    function resizeCanvas() {
      var rect = canvas.getBoundingClientRect();
      var dpr = Math.min(window.devicePixelRatio || 1, maxDpr);
      var width = Math.max(1, Math.floor(rect.width * dpr));
      var height = Math.max(1, Math.floor(rect.height * dpr));

      if (canvas.width !== width || canvas.height !== height) {
        canvas.width = width;
        canvas.height = height;

        if (hydra && typeof window.setResolution === 'function') {
          window.setResolution(width, height);
        }
      }
    }

    function requestResize() {
      if (resizeFrame) window.cancelAnimationFrame(resizeFrame);
      resizeFrame = window.requestAnimationFrame(resizeCanvas);
    }

    var s = document.createElement('script');
    s.src = 'https://cdn.jsdelivr.net/npm/hydra-synth@1.3.29/dist/hydra-synth.js';

    s.onload = function () {
      resizeCanvas();

      hydra = new Hydra({
        canvas: canvas,
        detectAudio: false,
        enableStreamCapture: false,
        pb: false,
      });

      if (typeof window.setResolution === 'function') {
        window.setResolution(canvas.width, canvas.height);
      }

      // Visual antiguo rescatado de c1sne.github.io:
      // shape/voronoi/pixelate con acumulación, ajustado solo para vivir
      // dentro de la nueva web.
      shape(6)
        .modulate(voronoi(2000))
        .pixelate(120, 68)
        .layer(noise(3).luma(0.1).scale(4, 4))
        .blend(src(o0).luma(0.1).modulate(voronoi(0.1)))
        .colorama(0.06, 0, 0.1)
        .blend(o0)
        .blend(o0)
        .out(o0);
    };

    s.onerror = function () {
      // fallback silencioso: el fondo oscuro del wrapper ya es presentable
    };

    document.head.appendChild(s);

    if ('ResizeObserver' in window) {
      var observer = new ResizeObserver(requestResize);
      observer.observe(canvas);
    } else {
      window.addEventListener('resize', requestResize, { passive: true });
    }
  })();
</script>

<style>
  .hydra-wrap {
    width: 100%;
    aspect-ratio: 16 / 9;
    position: relative;
    background: #0a0a0a;
    overflow: hidden;
  }

  #hydra-canvas {
    display: block;
    width: 100%;
    height: 100%;
    position: absolute;
    inset: 0;
    image-rendering: auto;
  }
</style>
