---
import MediaPlaceholder from './MediaPlaceholder.astro';

interface Props {
  title: string;
  slug: string;
  year: number;
  location?: string;
  categories: string[];
  shortDescription: string;
  coverImage?: string;
  featured?: boolean;
}

const { title, slug, year, location, categories, shortDescription, coverImage, featured } = Astro.props;
---

<article class={`project-card ${featured ? 'project-card--featured' : ''}`}>
  <a href={`/proyectos/${slug}`} class="card-link" tabindex="-1" aria-hidden="true">
    <div class="card-media">
      {coverImage ? (
        <img src={coverImage} alt={title} loading="lazy" decoding="async" />
      ) : (
        <MediaPlaceholder type="image" aspect="3/2" />
      )}
      {featured && <span class="featured-badge">Destacado</span>}
    </div>
  </a>

  <div class="card-body">
    <div class="card-meta">
      <span class="card-year">{year}</span>
      {location && <span class="card-sep">·</span>}
      {location && <span class="card-location">{location}</span>}
    </div>

    <h3 class="card-title">
      <a href={`/proyectos/${slug}`}>{title}</a>
    </h3>

    <p class="card-desc">{shortDescription}</p>

    <div class="card-categories">
      {categories.map(cat => (
        <span class="category-tag">{cat}</span>
      ))}
    </div>

    <a href={`/proyectos/${slug}`} class="card-cta">
      Ver proyecto <span aria-hidden="true">→</span>
    </a>
  </div>
</article>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-2);
    border: 1px solid var(--border);
    transition: border-color 0.25s ease;
  }

  .project-card:hover {
    border-color: var(--copper-dim);
  }

  .project-card--featured {
    border-color: rgba(184, 115, 51, 0.25);
  }

  .card-link {
    display: block;
    overflow: hidden;
  }

  .card-media {
    position: relative;
    overflow: hidden;
  }

  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
    aspect-ratio: 3/2;
  }

  .project-card:hover .card-media img {
    transform: scale(1.03);
  }

  .featured-badge {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--bg);
    background: var(--copper);
    padding: 0.2em 0.6em;
    z-index: 1;
  }

  .card-body {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 0.5rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    color: var(--text-dim);
    letter-spacing: 0.04em;
  }

  .card-title {
    font-size: 1.2rem;
    font-weight: 500;
    margin: 0;
  }

  .card-title a {
    color: var(--white);
    text-decoration: none;
    transition: color 0.2s;
  }

  .card-title a:hover {
    color: var(--copper-light);
  }

  .card-desc {
    font-size: 0.875rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .card-categories {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }

  .category-tag {
    font-family: var(--font-mono);
    font-size: 0.62rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--copper);
    border: 1px solid var(--copper-dim);
    padding: 0.15em 0.5em;
    background: rgba(184, 115, 51, 0.05);
  }

  .card-cta {
    font-size: 0.78rem;
    color: var(--copper-light);
    text-decoration: none;
    letter-spacing: 0.04em;
    margin-top: 0.5rem;
    transition: color 0.2s;
    align-self: flex-start;
  }

  .card-cta:hover {
    color: var(--white);
  }
</style>
